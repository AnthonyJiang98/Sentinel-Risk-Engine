{
  "name": "sentinel-risk-engine",
  "version": "1.0.0",
  "description": "Enterprise-grade financial surveillance platform",
  "private": true,
  "workspaces": [
    "sentinel-dashboard",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=sentinel-dashboard\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=sentinel-dashboard && npm run build --workspace=server",
    "start": "concurrently \"npm start --workspace=sentinel-dashboard\" \"npm start --workspace=server\"",
    "lint": "npm run lint --workspace=sentinel-dashboard"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
